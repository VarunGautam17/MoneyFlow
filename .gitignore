# Version control ignore rules for RupeeRadar

# Environments and Secrets
.env
.env.local
.env.*.local
*.env

# Python Virtual Environment
backend/venv/
backend/.venv/
venv/
.venv/
__pycache__/
*.pyc

# Node / JS Dependencies
node_modules/
frontend/node_modules/
dist/
frontend/dist/

# Local Databases
*.db
backend/*.db
rupeeradar.db
backend/rupeeradar.db

# IDEs and System Files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db
