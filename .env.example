# Database Connection URL
# For SQLite (default): sqlite:///./rupeeradar.db
# For PostgreSQL: postgresql://user:password@localhost:5432/rupeeradar
DATABASE_URL=sqlite:///./rupeeradar.db

# CORS Allowed Origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Maximum statement upload size in Megabytes
MAX_UPLOAD_SIZE_MB=10

# Groq API Key for Phase 2/3 LLM-based categorization fallback and insights
GROQ_API_KEY=
# LLM API Key (generic fallback or alias for GROQ_API_KEY)
LLM_API_KEY=
# Groq LLM Model name
GROQ_MODEL=llama-3.3-70b-versatile

