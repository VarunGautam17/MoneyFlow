# Database
# Local: SQLite file path
DATABASE_URL=sqlite:///./data/rupee_radar.db
# Production (Railway): PostgreSQL plugin connection string
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# CORS (comma-separated origins)
# Local dev + Vercel production/preview URLs
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Session privacy — auto-expire analysis data after N hours
SESSION_TTL_HOURS=72

# Groq LLM (categorization + narrative insights)
# Model: llama-3.3-70b-versatile — free tier: 30 RPM, 1K TPM, 12K RPD, 100K TPD
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Groq rate limits (match your console tier; defaults = llama-3.3-70b-versatile free)
GROQ_RPM=30
GROQ_TPM=1000
GROQ_RPD=12000
GROQ_TPD=100000

# LLM categorization guards (tuned for 1K TPM — small batches, upload cap)
GROQ_MAX_TOKENS_PER_REQUEST=350
GROQ_MAX_TXNS_PER_UPLOAD=15
GROQ_UPLOAD_TIME_BUDGET_SEC=45
GROQ_MAX_DESCRIPTION_CHARS=48

# Frontend (Vercel) — Railway API base URL, no trailing slash
# VITE_API_URL=https://your-app.up.railway.app
